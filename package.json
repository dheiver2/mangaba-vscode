{
  "name": "mangaba-ai",
  "displayName": "Mangaba AI",
  "description": "Chat com a IA brasileira e soberana Mangaba, dentro do VS Code — powered pelos modelos self-hosted (OpenAI-compatível).",
  "version": "0.3.2",
  "publisher": "mangaba",
  "icon": "media/icon-128.png",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/dheiver2/mangaba-vscode.git" },
  "bugs": { "url": "https://github.com/dheiver2/mangaba-vscode/issues" },
  "homepage": "https://mangaba.chat",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["AI", "Chat", "Machine Learning"],
  "keywords": ["mangaba", "ai", "chat", "brasil", "llm", "copilot", "soberana"],
  "galleryBanner": { "color": "#1E0D01", "theme": "dark" },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        { "id": "mangaba", "title": "Mangaba AI", "icon": "media/icon.svg" }
      ]
    },
    "views": {
      "mangaba": [
        { "type": "webview", "id": "mangaba.chatView", "name": "Chat" }
      ]
    },
    "commands": [
      { "command": "mangaba.openChat", "title": "Abrir chat", "category": "Mangaba AI" },
      { "command": "mangaba.newChat", "title": "Nova conversa", "category": "Mangaba AI", "icon": "$(add)" },
      { "command": "mangaba.explainSelection", "title": "Explicar seleção", "category": "Mangaba AI", "icon": "$(sparkle)" }
    ],
    "keybindings": [
      { "command": "mangaba.openChat", "key": "ctrl+alt+m", "mac": "cmd+alt+m" },
      { "command": "mangaba.explainSelection", "key": "ctrl+alt+e", "mac": "cmd+alt+e", "when": "editorHasSelection" }
    ],
    "menus": {
      "view/title": [
        { "command": "mangaba.newChat", "when": "view == mangaba.chatView", "group": "navigation" }
      ],
      "editor/context": [
        { "command": "mangaba.explainSelection", "when": "editorHasSelection", "group": "1_mangaba" }
      ],
      "commandPalette": [
        { "command": "mangaba.newChat", "when": "false" }
      ]
    },
    "configuration": {
      "title": "Mangaba AI",
      "properties": {
        "mangaba.baseUrl": {
          "type": "string",
          "default": "https://walton-undepreciatory-tracee.ngrok-free.dev/v1",
          "markdownDescription": "Endpoint **OpenAI-compatível** do servidor Mangaba (raiz terminando em `/v1`). É daqui que a extensão lista os modelos e faz o streaming do chat.",
          "order": 1
        },
        "mangaba.model": {
          "type": "string",
          "default": "mangaba-pro",
          "enum": ["mangaba-pro", "mangaba-max", "mangaba-lite-q4", "mangaba-vision-q8"],
          "enumDescriptions": [
            "8B — equilíbrio entre qualidade e velocidade",
            "9B — foco em raciocínio",
            "Q4 — rápido e leve",
            "Multimodal (texto + visão)"
          ],
          "markdownDescription": "Modelo inicial. O **seletor no topo do chat** lista os modelos do servidor e sobrepõe esta opção.",
          "order": 2
        },
        "mangaba.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Bearer token (opcional — o Mangaba self-hosted é *keyless*).",
          "order": 3
        },
        "mangaba.temperature": {
          "type": "number", "default": 0.7, "minimum": 0, "maximum": 2,
          "markdownDescription": "Temperatura de amostragem (0 = determinístico, 2 = criativo).",
          "order": 4
        },
        "mangaba.maxTokens": {
          "type": "number", "default": 4096, "minimum": 1,
          "markdownDescription": "Máximo de tokens na resposta.",
          "order": 5
        }
      }
    },
    "walkthroughs": [
      {
        "id": "mangaba.getStarted",
        "title": "Comece com a Mangaba AI",
        "description": "Configure e use a IA brasileira e soberana Mangaba dentro do VS Code.",
        "steps": [
          {
            "id": "open",
            "title": "Abra o chat",
            "description": "Clique no ícone **Mangaba AI** na Activity Bar, ou rode o comando.\n\n[Abrir chat](command:mangaba.openChat)",
            "media": { "image": "media/icon-128.png", "altText": "Mangaba AI" }
          },
          {
            "id": "model",
            "title": "Escolha o modelo",
            "description": "No topo do painel, o seletor lista os modelos do seu servidor (`mangaba-pro`, `max`, `lite`, `vision`). Troque quando quiser — a escolha fica salva.",
            "media": { "image": "media/icon-128.png", "altText": "Seletor de modelo" }
          },
          {
            "id": "explain",
            "title": "Explique código",
            "description": "Selecione um trecho no editor e use **Explicar seleção** (`Cmd/Ctrl+Alt+E`) ou o menu de contexto.",
            "media": { "image": "media/icon-128.png", "altText": "Explicar seleção" },
            "completionEvents": ["onCommand:mangaba.explainSelection"]
          },
          {
            "id": "config",
            "title": "Aponte para o seu servidor",
            "description": "Ajuste `mangaba.baseUrl` para o seu endpoint OpenAI-compatível.\n\n[Abrir configurações](command:workbench.action.openSettings?%22mangaba%22)",
            "media": { "image": "media/icon-128.png", "altText": "Configurações" }
          }
        ]
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "vscode:prepublish": "node esbuild.js --production",
    "package": "npx --yes @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "typescript": "^5"
  }
}
