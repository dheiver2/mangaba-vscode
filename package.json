{
  "name": "mangaba-ai",
  "displayName": "Mangaba AI",
  "description": "Chat com a IA brasileira e soberana Mangaba, dentro do VS Code — powered pelos modelos self-hosted (OpenAI-compatível).",
  "version": "0.11.7",
  "publisher": "mangaba-ai",
  "icon": "media/icon-128.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dheiver2/mangaba-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/dheiver2/mangaba-vscode/issues"
  },
  "homepage": "https://mangaba.ia.br",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Machine Learning"
  ],
  "keywords": [
    "mangaba",
    "ai",
    "chat",
    "brasil",
    "llm",
    "copilot",
    "soberana"
  ],
  "galleryBanner": {
    "color": "#1E0D01",
    "theme": "dark"
  },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mangaba",
          "title": "Mangaba AI",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "mangaba": [
        {
          "type": "webview",
          "id": "mangaba.chatView",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "mangaba.openChat",
        "title": "Abrir chat",
        "category": "Mangaba AI"
      },
      {
        "command": "mangaba.newChat",
        "title": "Nova conversa",
        "category": "Mangaba AI",
        "icon": "$(add)"
      },
      {
        "command": "mangaba.explainSelection",
        "title": "Explicar seleção",
        "category": "Mangaba AI",
        "icon": "$(sparkle)"
      },
      {
        "command": "mangaba.editSelection",
        "title": "Editar seleção (IA)",
        "category": "Mangaba AI",
        "icon": "$(wand)"
      },
      {
        "command": "mangaba.agentTask",
        "title": "Tarefa no projeto (agente)",
        "category": "Mangaba AI",
        "icon": "$(rocket)"
      },
      {
        "command": "mangaba.generateTests",
        "title": "Gerar testes",
        "category": "Mangaba AI",
        "icon": "$(beaker)"
      },
      {
        "command": "mangaba.fixDiagnostics",
        "title": "Corrigir erros com IA",
        "category": "Mangaba AI",
        "icon": "$(lightbulb-autofix)"
      },
      {
        "command": "mangaba.commitMessage",
        "title": "Gerar mensagem de commit",
        "category": "Mangaba AI",
        "icon": "$(sparkle)"
      },
      {
        "command": "mangaba.pickContext",
        "title": "Adicionar contexto (@)",
        "category": "Mangaba AI",
        "icon": "$(mention)"
      },
      {
        "command": "mangaba.openHistory",
        "title": "Conversas salvas",
        "category": "Mangaba AI",
        "icon": "$(history)"
      },
      {
        "command": "mangaba.indexProject",
        "title": "Indexar projeto (RAG @codebase)",
        "category": "Mangaba AI",
        "icon": "$(database)"
      },
      {
        "command": "mangaba.agentLoop",
        "title": "Agente autônomo (tarefa)",
        "category": "Mangaba AI",
        "icon": "$(run-all)"
      },
      {
        "command": "mangaba.undoAgent",
        "title": "Desfazer sessão do agente",
        "category": "Mangaba AI",
        "icon": "$(discard)"
      }
    ],
    "keybindings": [
      {
        "command": "mangaba.openChat",
        "key": "ctrl+alt+m",
        "mac": "cmd+alt+m"
      },
      {
        "command": "mangaba.explainSelection",
        "key": "ctrl+alt+e",
        "mac": "cmd+alt+e",
        "when": "editorHasSelection"
      },
      {
        "command": "mangaba.editSelection",
        "key": "ctrl+alt+k",
        "mac": "cmd+alt+k",
        "when": "editorHasSelection"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "mangaba.newChat",
          "when": "view == mangaba.chatView",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "mangaba.editSelection",
          "when": "editorHasSelection",
          "group": "1_mangaba@1"
        },
        {
          "command": "mangaba.explainSelection",
          "when": "editorHasSelection",
          "group": "1_mangaba@2"
        },
        {
          "command": "mangaba.generateTests",
          "group": "1_mangaba@3"
        }
      ],
      "scm/title": [
        {
          "command": "mangaba.commitMessage",
          "when": "scmProvider == git",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "mangaba.newChat",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "Mangaba AI",
      "properties": {
        "mangaba.baseUrl": {
          "type": "string",
          "default": "https://walton-undepreciatory-tracee.ngrok-free.dev/v1",
          "markdownDescription": "Endpoint **OpenAI-compatível** do servidor Mangaba (raiz terminando em `/v1`). Já vem apontando para o servidor Mangaba; troque pelo **seu** se preferir.",
          "order": 1
        },
        "mangaba.model": {
          "type": "string",
          "default": "mangaba-pro",
          "enum": [
            "mangaba-pro",
            "mangaba-max",
            "mangaba-lite-q4",
            "mangaba-vision-q8"
          ],
          "enumDescriptions": [
            "8B — equilíbrio entre qualidade e velocidade",
            "9B — foco em raciocínio",
            "Q4 — rápido e leve",
            "Multimodal (texto + visão)"
          ],
          "markdownDescription": "Modelo inicial. O **seletor no topo do chat** lista os modelos do servidor e sobrepõe esta opção.",
          "order": 2
        },
        "mangaba.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Bearer token (opcional — o Mangaba self-hosted é *keyless*).",
          "order": 3
        },
        "mangaba.temperature": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 2,
          "markdownDescription": "Temperatura de amostragem (0 = determinístico, 2 = criativo).",
          "order": 4
        },
        "mangaba.maxTokens": {
          "type": "number",
          "default": 4096,
          "minimum": 1,
          "markdownDescription": "Máximo de tokens na resposta.",
          "order": 5
        },
        "mangaba.includeActiveFile": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Envia o **arquivo/seleção ativos** como contexto para o chat, para o modelo entender o código que você está escrevendo.",
          "order": 6
        },
        "mangaba.maxContextChars": {
          "type": "number",
          "default": 6000,
          "minimum": 500,
          "markdownDescription": "Máximo de caracteres do arquivo enviados como contexto (evita estourar a janela do modelo).",
          "order": 7
        },
        "mangaba.reviewBeforeApply": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Mostra um **diff (atual × proposto)** e pede confirmação antes de aplicar o código no editor. Desligue para aplicar direto.",
          "order": 8
        },
        "mangaba.inlineCompletions": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "**Autocompletar inline (ghost text)** enquanto você digita. *Opt-in:* os modelos Mangaba de 8K não são de baixa latência, então a sugestão pode demorar — melhor com um endpoint rápido. Aciona manualmente com `Alt+\\`.",
          "order": 9
        },
        "mangaba.useCodebaseContext": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Usa o **índice local do projeto** (RAG @codebase) para recuperar trechos relevantes e injetá-los no chat. Rode **Mangaba AI: Indexar projeto** primeiro. Embeddings 100% locais (transformers.js), nada sai da máquina.",
          "order": 10
        },
        "mangaba.embeddingsBackend": {
          "type": "string",
          "enum": [
            "transformers",
            "ollama"
          ],
          "default": "transformers",
          "enumDescriptions": [
            "Local, embutido (transformers.js) — self-contained, mas o vsix fica grande/por-plataforma",
            "Ollama local (HTTP) — vsix leve/portátil; exige Ollama + `ollama pull nomic-embed-text`"
          ],
          "markdownDescription": "Backend de **embeddings** do RAG @codebase.",
          "order": 11
        },
        "mangaba.ollamaEmbedUrl": {
          "type": "string",
          "default": "http://localhost:11434/api/embeddings",
          "markdownDescription": "URL de embeddings do Ollama (quando `embeddingsBackend = ollama`).",
          "order": 12
        },
        "mangaba.ollamaEmbedModel": {
          "type": "string",
          "default": "nomic-embed-text",
          "markdownDescription": "Modelo de embedding do Ollama.",
          "order": 13
        },
        "mangaba.commandApproval": {
          "type": "string",
          "enum": [
            "always",
            "never"
          ],
          "default": "always",
          "enumDescriptions": [
            "Pede aprovação a cada comando (recomendado)",
            "Roda comandos sem perguntar (cuidado)"
          ],
          "markdownDescription": "Aprovação de comandos de terminal do **agente autônomo**.",
          "order": 14
        },
        "mangaba.testCommand": {
          "type": "string",
          "default": "",
          "markdownDescription": "Comando de teste sugerido ao agente (ex.: `npm test`, `pytest`). Ajuda a auto-verificação.",
          "order": 15
        },
        "mangaba.agentMaxSteps": {
          "type": "number",
          "default": 12,
          "minimum": 1,
          "maximum": 40,
          "markdownDescription": "Máximo de passos do laço agêntico.",
          "order": 16
        },
        "mangaba.mcpServers": {
          "type": "array",
          "default": [],
          "markdownDescription": "Servidores **MCP** (stdio) disponíveis para o agente. Ex.: `[{ \"name\": \"fs\", \"command\": \"npx\", \"args\": [\"-y\",\"@modelcontextprotocol/server-filesystem\",\".\"] }]`.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "command": {
                "type": "string"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "name",
              "command"
            ]
          },
          "order": 17
        }
      }
    },
    "walkthroughs": [
      {
        "id": "mangaba.getStarted",
        "title": "Comece com a Mangaba AI",
        "description": "Configure e use a IA brasileira e soberana Mangaba dentro do VS Code.",
        "steps": [
          {
            "id": "open",
            "title": "Abra o chat",
            "description": "Clique no ícone **Mangaba AI** na Activity Bar, ou rode o comando.\n\n[Abrir chat](command:mangaba.openChat)",
            "media": {
              "image": "media/icon-128.png",
              "altText": "Mangaba AI"
            }
          },
          {
            "id": "model",
            "title": "Escolha o modelo",
            "description": "No topo do painel, o seletor lista os modelos do seu servidor (`mangaba-pro`, `max`, `lite`, `vision`). Troque quando quiser — a escolha fica salva.",
            "media": {
              "image": "media/icon-128.png",
              "altText": "Seletor de modelo"
            }
          },
          {
            "id": "explain",
            "title": "Explique código",
            "description": "Selecione um trecho no editor e use **Explicar seleção** (`Cmd/Ctrl+Alt+E`) ou o menu de contexto.",
            "media": {
              "image": "media/icon-128.png",
              "altText": "Explicar seleção"
            },
            "completionEvents": [
              "onCommand:mangaba.explainSelection"
            ]
          },
          {
            "id": "config",
            "title": "Aponte para o seu servidor",
            "description": "Ajuste `mangaba.baseUrl` para o seu endpoint OpenAI-compatível.\n\n[Abrir configurações](command:workbench.action.openSettings?%22mangaba%22)",
            "media": {
              "image": "media/icon-128.png",
              "altText": "Configurações"
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "vscode:prepublish": "node esbuild.js --production",
    "test": "tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "package": "npx --yes @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "pdfjs-dist": "^4.10.38"
  }
}
